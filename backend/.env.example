# ----- Core -----
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/reset-password

# ----- Database -----
# DB_ENGINE = sqlite | postgresql | mysql
DB_ENGINE=postgresql
DB_NAME=talent_center
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# ----- Email -----
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@talent-center.local
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# ----- Auth policy -----
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_FAILED_WINDOW_SECONDS=900
AUTH_LOCKOUT_SECONDS=900
PASSWORD_RESET_TOKEN_TTL_SECONDS=1800
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# ----- Providers (remote providers default OFF) -----
AUTH0_ENABLED=False
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_REDIRECT_URI=
AUTH0_JIT=True

MS_ENABLED=False
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=
MS_JIT=True

SSO_ENABLED=False
SSO_METADATA_URL=
SSO_JIT=False
